# FossilAI — Environment Variables
# Copy this file to .env and fill in your API keys.

# Gemini 2.5 Flash API Key (required)
# Get yours at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (required)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# GitHub Personal Access Token (optional — recommended)
# Without a token: 60 requests/hour. With a token: 5,000 requests/hour.
# Create one at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here
